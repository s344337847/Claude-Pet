{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "-e",
              "require('http').request({hostname:'127.0.0.1',port:9876,path:'/v1/event',method:'POST',headers:{'Content-Type':'application/json'}},res=>process.exit(0)).on('error',()=>process.exit(0)).end(JSON.stringify({event:'work'}))"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "-e",
              "require('http').request({hostname:'127.0.0.1',port:9876,path:'/v1/event',method:'POST',headers:{'Content-Type':'application/json'}},res=>process.exit(0)).on('error',()=>process.exit(0)).end(JSON.stringify({event:'success'}))"
            ]
          }
        ]
      }
    ]
  }
}
