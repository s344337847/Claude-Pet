{
  "hooks": {
    "task_status_change": {
      "command": "curl",
      "args": [
        "-s", "-X", "POST",
        "http://127.0.0.1:9876/v1/event",
        "-H", "Content-Type: application/json",
        "-d", "{\"type\":\"task_status_change\",\"task_id\":\"{{task_id}}\",\"status\":\"{{status}}\",\"subject\":\"{{subject}}\",\"timestamp\":\"{{timestamp}}\"}"
      ]
    }
  }
}
