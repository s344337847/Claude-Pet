{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl",
            "args": [
              "-s", "-X", "POST",
              "http://127.0.0.1:9876/v1/event",
              "-H", "Content-Type: application/json",
              "-d", "{\"event\":\"work\"}"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl",
            "args": [
              "-s", "-X", "POST",
              "http://127.0.0.1:9876/v1/event",
              "-H", "Content-Type: application/json",
              "-d", "{\"event\":\"success\"}"
            ]
          }
        ]
      }
    ]
  }
}
